# Dev DB. No local postgres on this machine — port-forward the cluster one:
#   kubectl port-forward svc/postgres 5432:5432 -n monarch
# then create the database once (psql isn't installed locally, exec into the pod):
#   kubectl exec -n monarch statefulset/postgres -- psql -U postgres -c 'CREATE DATABASE duo_tracker'
DB_URL=postgresql+psycopg://postgres:CHANGEME@localhost:5432/duo_tracker

# Comma-separated list of people to snapshot. Each needs a DUO_JWT_<NAME> below.
DUO_PEOPLE=kyle

# Harvested Duolingo JWTs, one per person. To harvest:
#   1. Log into duolingo.com in a browser as that person
#   2. DevTools -> Application -> Cookies -> https://www.duolingo.com
#   3. Copy the value of the `jwt_token` cookie
# Tokens are long-lived; re-harvest when `duo-tracker snapshot` reports a
# DuoAuthError for that person.
DUO_JWT_KYLE=
# DUO_JWT_LINDSEY=
# DUO_JWT_WALKER=
